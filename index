<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <style>
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100vh;
      background: transparent;
    }
    .card {
      text-align: center;
      padding: 20px 40px;
      border-radius: 12px;
      background: #f7f6f3;
      border: 1px solid #e5e4e0;
    }
    .label { font-size: 13px; color: #9b9a97; text-transform: uppercase; letter-spacing: 1px; }
    .date  { font-size: 16px; color: #37352f; margin: 4px 0 12px; font-weight: 500; }
    .count { font-size: 52px; font-weight: 700; color: #e03e3e; line-height: 1; }
    .unit  { font-size: 14px; color: #9b9a97; margin-top: 6px; }
  </style>
</head>
<body>
  <div class="card">
    <div class="label">Soutenance</div>
    <div class="date">03 avril 2026</div>
    <div class="count" id="days">--</div>
    <div class="unit">jours restants</div>
  </div>
  <script>
    const target = new Date('2026-04-03');
    const today  = new Date();
    today.setHours(0, 0, 0, 0);
    const diff = Math.ceil((target - today) / (1000 * 60 * 60 * 24));
    document.getElementById('days').textContent = diff > 0 ? diff : '🎓';
  </script>
</body>
</html>
